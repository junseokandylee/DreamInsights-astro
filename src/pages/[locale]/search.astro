---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { query } from '../../lib/db';
import { t } from '../../lib/i18n';
import { getLPath, BASE_URL } from '../../lib/locale';
import { LOCALES, SEO_CONFIG, type Locale } from '../../../shared/lib/i18n/config';

export function getStaticPaths() {
  return LOCALES.map(locale => ({ params: { locale } }));
}

export const prerender = false;

const { locale } = Astro.params as { locale: Locale };
const seoConfig = SEO_CONFIG[locale];

// ── Bot Detection ─────────────────────────────
const ua = Astro.request.headers.get('user-agent') || '';
const BOT_PATTERNS = /bot|crawl|spider|slurp|mediapartners|preview|fetch|curl|wget|python|java|httpclient|scrapy|phantom|selenium|headless/i;
function isLikelyBot(userAgent: string): boolean { return BOT_PATTERNS.test(userAgent); }

// ── Rate Limiter ───────────────────────────────
const searchLimiter = new Map<string, { count: number; resetAt: number }>();
const RATE_LIMIT = 10;
const RATE_WINDOW = 60_000;
function isRateLimited(ip: string): boolean {
  const now = Date.now();
  const entry = searchLimiter.get(ip);
  if (!entry || now > entry.resetAt) { searchLimiter.set(ip, { count: 1, resetAt: now + RATE_WINDOW }); return false; }
  entry.count++;
  return entry.count > RATE_LIMIT;
}
if (searchLimiter.size > 10000) { const now = Date.now(); for (const [key, val] of searchLimiter) { if (now > val.resetAt) searchLimiter.delete(key); } }

// ── Request Validation ─────────────────────────
const q = Astro.url.searchParams.get('q') || '';
const decodedQ = decodeURIComponent(q);
const honeypot = Astro.url.searchParams.get('website') || '';
const clientCheck = Astro.url.searchParams.get('_ts') || '';
const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim()
  || Astro.request.headers.get('cf-connecting-ip') || 'unknown';
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10) || 1);
const PER_PAGE = 24;

let blocked = false;
if (honeypot.length > 0) blocked = true;
if (!blocked && decodedQ.trim().length >= 2) {
  const ts = parseInt(clientCheck, 10);
  const now = Date.now();
  if (!clientCheck || isNaN(ts) || ts < now - 300000 || ts > now + 60000) blocked = true;
}
if (!blocked && isRateLimited(clientIp)) blocked = true;
if (!blocked && isLikelyBot(ua)) blocked = true;

// ── Search Execution ──────────────────────────
let dreams: any[] = [];
let totalCount = 0;
let totalPages = 1;

if (decodedQ.trim() && !blocked) {
  const searchTerm = `%${decodedQ.trim()}%`;
  const offset = (page - 1) * PER_PAGE;
  const [results, count] = await Promise.all([
    query<any>(`SELECT d.id, d.original_slug as slug, d.views, t.title, t.summary, t.content, c.name as category_name, c.slug as category_slug FROM dream_interpretations d JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = $1 AND t.is_active = true LEFT JOIN categories c ON d.category_id = c.id WHERE d.is_active = true AND (t.title ILIKE $2 OR t.content ILIKE $2 OR t.summary ILIKE $2 OR d.original_slug ILIKE $2) ORDER BY d.views DESC NULLS LAST LIMIT $3 OFFSET $4`, [locale, searchTerm, PER_PAGE, offset]),
    query<any>(`SELECT COUNT(*) as total FROM dream_interpretations d JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = $1 AND t.is_active = true WHERE d.is_active = true AND (t.title ILIKE $2 OR t.content ILIKE $2 OR t.summary ILIKE $2 OR d.original_slug ILIKE $2)`, [locale, searchTerm])
  ]);
  dreams = results;
  totalCount = count[0]?.total || 0;
  totalPages = Math.ceil(totalCount / PER_PAGE);
}

const pageTitle = decodedQ ? `"${decodedQ}" - ${seoConfig.siteName}` : `${t(locale, 'nav.search')} - ${seoConfig.siteName}`;
const pageDesc = decodedQ ? `"${decodedQ}" ${t(locale, 'search.resultsFound')}` : t(locale, 'nav.search');
---

<BaseLayout title={pageTitle} description={pageDesc} locale={locale} alternatePath="/search">
  <meta name="robots" content="noindex, follow" />
  {totalPages > 1 && (
    <link rel="canonical" href={`${BASE_URL}${getLPath(locale, '/search')}?q=${q}&page=${page}`} />
  )}
  {page > 1 && <link rel="prev" href={`${BASE_URL}${getLPath(locale, '/search')}?q=${q}&page=${page - 1}`} />}
  {page < totalPages && <link rel="next" href={`${BASE_URL}${getLPath(locale, '/search')}?q=${q}&page=${page + 1}`} />}
  <main id="main-content" class="container-wide page-section">

    <form id="search-form" action={getLPath(locale, '/search')} method="get" class="search-form">
      <div class="search-input-wrap">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="search" name="q" class="search-input" value={decodedQ} placeholder={t(locale, 'search.placeholder')} autocomplete="off" autofocus={!!decodedQ} />
        <input type="text" name="website" value="" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
        <input type="hidden" name="_ts" id="search-ts" value="" />
      </div>
    </form>

    {blocked ? (
      <div class="empty-state">
        <p class="empty-state-title"><span aria-hidden="true">🤖</span></p>
        <p class="empty-state-desc empty-state-desc-center"></p>
      </div>
    ) : decodedQ.trim() ? (
      <div>
        <h1 class="text-sm text-tertiary mb-6 search-result-title">
          "<span class="text-medium search-result-query">{decodedQ}</span>"
          <span class="text-accent search-result-count">{totalCount.toLocaleString()}</span>
        </h1>

        {dreams.length > 0 ? (
          <>
            <div class="dream-grid">
              {dreams.map((dream: any) => (
                <a href={getLPath(locale, `/dream/${dream.slug}`)} class="card dream-card">
                  <div class="dream-card-meta">
                    {dream.category_name && <span class="category-pill">{dream.category_name}</span>}
                    <span class="dream-card-views">👁 {(dream.views || 0).toLocaleString()}</span>
                  </div>
                  <h3 class="dream-card-title">{dream.title}</h3>
                  <p class="dream-card-summary">{dream.summary || dream.content?.slice(0, 120)}</p>
                </a>
              ))}
            </div>

            {totalPages > 1 && (
              <nav class="pagination" aria-label="Pagination">
                {page > 1 ? <a href={`${getLPath(locale, '/search')}?q=${q}&_ts=0&page=${page - 1}`}>←</a> : <span class="disabled">←</span>}
                {Array.from({ length: Math.min(totalPages, 7) }, (_, i) => {
                  const start = page <= 4 ? 1 : Math.max(1, page - 3);
                  const end = Math.min(totalPages, start + 6);
                  if (i + start > end) return null;
                  const p = i + start;
                  return p === page ? <span class="active">{p}</span> : <a href={`${getLPath(locale, '/search')}?q=${q}&_ts=0&page=${p}`}>{p}</a>;
                })}
                {page < totalPages ? <a href={`${getLPath(locale, '/search')}?q=${q}&_ts=0&page=${page + 1}`}>→</a> : <span class="disabled">→</span>}
              </nav>
            )}
          </>
        ) : (
          <div class="empty-state">
            <p class="empty-state-title">{t(locale, 'search.noResults')}</p>
            <p class="empty-state-desc">{t(locale, 'search.tryOtherKeywords')}</p>
          </div>
        )}
      </div>
    ) : (
      <div class="empty-state">
        <h1 class="empty-state-title"><span aria-hidden="true">🔍</span> {t(locale, 'nav.search')}</h1>
        <p class="empty-state-desc empty-state-desc-mb">{t(locale, 'search.placeholder')}</p>
      </div>
    )}
  </main>

  <script is:inline>
    document.getElementById('search-form').addEventListener('submit', () => { document.getElementById('search-ts').value = Date.now(); });
  </script>
</BaseLayout>
