---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { query } from '../../lib/db';

const categories = await query<any>(`
  SELECT c.name, c.slug, COUNT(*) as dream_count
  FROM categories c
  JOIN dream_interpretations d ON d.category_id = c.id AND d.is_active = true
  JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true
  GROUP BY c.name, c.slug
  HAVING COUNT(*) > 0
  ORDER BY COUNT(*) DESC
`);

const ICONS: Record<string, string> = {
  animal: '🐾', nature: '🌿', money: '💰', person: '👤', death: '🪦',
  food: '🍽️', traffic: '🚗', house: '🏠', marriage: '💍', birth: '👶'
};
---

<BaseLayout title="꿈 해몽 카테고리 - 드림디비" description="동물, 자연, 사람, 돈, 건강 등 카테고리별 꿈 해몽을 확인하세요.">
  <div class="max-w-[var(--max-width-content)] mx-auto px-4 page-section">
    <h1 class="heading-1 mb-3">카테고리</h1>
    <p class="text-secondary mb-8">관심 있는 카테고리를 선택해 꿈 해몽을 확인하세요.</p>

    <div class="category-grid">
      {categories.map((cat: any) => (
        <a href={`/category/${cat.slug}`} class="card category-card">
          <div class="category-icon">{ICONS[cat.slug] || '🌙'}</div>
          <h2 class="category-card-name">{cat.name}</h2>
          <span class="text-xs text-tertiary">{cat.dream_count.toLocaleString()}개 해몽</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
