---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { query } from '../../lib/db';

export const prerender = false;

const { slug } = Astro.params;
const decodedSlug = decodeURIComponent(slug || 'all');
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10) || 1);
const PER_PAGE = 24;

let category = null;
let categoryName = '전체 카테고리';
const categoryList = await query<any>(`
  SELECT name, slug, COUNT(*) as dream_count FROM categories c
  JOIN dream_interpretations d ON d.category_id = c.id AND d.is_active = true
  JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true
  GROUP BY c.name, c.slug HAVING COUNT(*) > 0 ORDER BY COUNT(*) DESC
`);

if (slug && slug !== 'all') {
  const cats = await query<any>(`SELECT name, slug FROM categories WHERE slug = $1`, [decodedSlug]);
  category = cats[0];
  categoryName = category?.name || decodedSlug;
}

const offset = (page - 1) * PER_PAGE;
const [dreams, countResult] = await Promise.all([
  query<any>(`SELECT d.id, d.original_slug as slug, d.views, t.title, t.summary, t.content, c.name as category_name, c.slug as category_slug FROM dream_interpretations d JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true LEFT JOIN categories c ON d.category_id = c.id ${category ? `WHERE d.category_id = (SELECT id FROM categories WHERE slug = $1)` : 'WHERE 1=1'} AND d.is_active = true ORDER BY d.views DESC NULLS LAST LIMIT ${PER_PAGE} OFFSET ${offset}`, category ? [decodedSlug] : []),
  query<any>(`SELECT COUNT(*) as total FROM dream_interpretations d JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true ${category ? `WHERE d.category_id = (SELECT id FROM categories WHERE slug = $1)` : 'WHERE 1=1'} AND d.is_active = true`, category ? [decodedSlug] : [])
]);

const totalCount = countResult[0]?.total || 0;
const totalPages = Math.ceil(totalCount / PER_PAGE);
const baseUrl = 'https://dream-db.net';
---

<BaseLayout title={`${categoryName} 꿈 해몽 - 드림디비`} description={`${categoryName}에 관련된 꿈 해몽을 확인하세요.`}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "홈", "item": baseUrl },
      { "@type": "ListItem", "position": 2, "name": "카테고리", "item": `${baseUrl}/category` },
      ...(category ? [{ "@type": "ListItem", "position": 3, "name": categoryName, "item": `${baseUrl}/category/${category.slug}` }] : [])
    ]
  })} />

  <main id="main-content" class="container-wide page-section">
    <nav class="breadcrumb mb-6" aria-label="Breadcrumb">
      <a href="/">홈</a><span class="separator">›</span><a href="/category">카테고리</a>
      {category && (<><span class="separator">›</span><span class="text-secondary">{categoryName}</span></>)}
    </nav>

    <nav class="category-nav">
      <a href="/category" class:list={['category-pill', { 'category-nav-active': !category }]}>전체</a>
      {categoryList.map((cat: any) => (
        <a href={`/category/${cat.slug}`} class:list={['category-pill', { 'category-nav-active': category?.slug === cat.slug }]}>
          {cat.name} <span class="category-nav-count">{cat.dream_count}</span>
        </a>
      ))}
    </nav>

    <div class="mb-8">
      <h1 class="heading-1 mb-2">{categoryName} 꿈 해몽</h1>
      <p class="text-secondary">총 {totalCount.toLocaleString()}개의 해몽</p>
    </div>

    <div class="dream-grid">
      {dreams.map((dream: any) => (
        <a href={`/dream/${dream.slug}`} class="card dream-card">
          <div class="dream-card-meta">
            {dream.category_name && <span class="category-pill">{dream.category_name}</span>}
            <span class="dream-card-views">👁 {(dream.views || 0).toLocaleString()}</span>
          </div>
          <h3 class="dream-card-title">{dream.title}</h3>
          <p class="dream-card-summary">{dream.summary || dream.content?.slice(0, 120)}</p>
        </a>
      ))}
    </div>

    {totalPages > 1 && (
      <nav class="pagination" aria-label="카테고리 페이지">
        {page > 1 ? <a href={category ? `/category/${category.slug}?page=${page - 1}` : `/category?page=${page - 1}`}>←</a> : <span class="disabled">←</span>}
        {Array.from({ length: Math.min(totalPages, 7) }, (_, i) => {
          const start = page <= 4 ? 1 : Math.max(1, page - 3);
          const end = Math.min(totalPages, start + 6);
          if (i + start > end) return null;
          const p = i + start;
          const href = category ? `/category/${category.slug}?page=${p}` : `/category?page=${p}`;
          return p === page ? <span class="active">{p}</span> : <a href={href}>{p}</a>;
        })}
        {page < totalPages ? <a href={category ? `/category/${category.slug}?page=${page + 1}` : `/category?page=${page + 1}`}>→</a> : <span class="disabled">→</span>}
      </nav>
    )}
  </main>
</BaseLayout>
