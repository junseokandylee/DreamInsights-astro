---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { query } from '../../lib/db';

export const prerender = false;

const { slug } = Astro.params;
const decodedSlug = decodeURIComponent(slug || 'all');

// Category info
let category = null;
let categoryName = '전체 카테고리';
const categoryList = await query<any>(`
  SELECT name, slug, COUNT(*) as dream_count
  FROM categories c
  JOIN dream_interpretations d ON d.category_id = c.id AND d.is_active = true
  JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true
  GROUP BY c.name, c.slug
  HAVING COUNT(*) > 0
  ORDER BY COUNT(*) DESC
`);

if (slug && slug !== 'all') {
  const cats = await query<any>(`SELECT name, slug FROM categories WHERE slug = $1`, [decodedSlug]);
  category = cats[0];
  categoryName = category?.name || decodedSlug;
}

// Dreams
const dreams = await query<any>(`
  SELECT d.id, d.original_slug as slug, d.views,
         t.title, t.summary, t.content,
         c.name as category_name, c.slug as category_slug
  FROM dream_interpretations d
  JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true
  LEFT JOIN categories c ON d.category_id = c.id
  ${category ? `WHERE d.category_id = (SELECT id FROM categories WHERE slug = $1)` : ''}
  AND d.is_active = true
  ORDER BY d.views DESC NULLS LAST
  LIMIT 24
`, category ? [decodedSlug] : []);
---

<BaseLayout title={`${categoryName} 꿈 해몽 - 드림디비`} description={`${categoryName}에 관련된 꿈 해몽을 확인하세요. 드림디비 AI 꿈 해몽 사전.`}>
  <div style="max-width:var(--max-width-wide); margin:0 auto; padding:var(--space-8) var(--space-4);">

    <!-- Category Nav -->
    <nav style="display:flex; flex-wrap:wrap; gap:var(--space-2); margin-bottom:var(--space-8); padding-bottom:var(--space-6); border-bottom:1px solid var(--color-border-default);">
      <a href="/category" class:list={[
        'category-pill',
        { 'category-pill-active': !category }
      ]} style={!category ? 'background:var(--color-dream-primary);color:white;' : ''}>전체</a>
      {categoryList.map((cat: any) => (
        <a href={`/category/${cat.slug}`} class="category-pill" style={category?.slug === cat.slug ? 'background:var(--color-dream-primary);color:white;' : ''}>
          {cat.name} <span style="opacity:0.6; margin-left:2px;">{cat.dream_count}</span>
        </a>
      ))}
    </nav>

    <!-- Header -->
    <div style="margin-bottom:var(--space-8);">
      <h1 class="heading-1" style="margin-bottom:var(--space-2);">{categoryName} 꿈 해몽</h1>
      <p style="font-size:var(--font-size-base); color:var(--color-text-secondary);">
        {categoryName === '전체 카테고리' ? '모든 카테고리의 꿈 해몽 목록입니다.' : `"${categoryName}" 카테고리의 꿈 해몽 목록입니다.`}
      </p>
    </div>

    <!-- Dream Grid -->
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:var(--space-4);">
      {dreams.map((dream: any) => (
        <a href={`/dream/${dream.slug}`} class="card" style="padding:var(--space-5); text-decoration:none; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; gap:var(--space-2); margin-bottom:var(--space-3);">
            {dream.category_name && <span class="category-pill">{dream.category_name}</span>}
            <span style="margin-left:auto; font-size:var(--font-size-xs); color:var(--color-text-tertiary);">👁 {(dream.views || 0).toLocaleString()}</span>
          </div>
          <h3 style="font-family:var(--font-family-display); font-size:var(--font-size-md); font-weight:var(--font-weight-semibold); color:var(--color-text-primary); line-height:var(--line-height-snug); margin-bottom:var(--space-2); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
            {dream.title}
          </h3>
          <p style="font-size:var(--font-size-sm); color:var(--color-text-secondary); line-height:var(--line-height-normal); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; flex:1;">
            {dream.summary || dream.content?.slice(0, 120)}
          </p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
