---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="페이지를 찾을 수 없습니다 - 드림디비">
  <main class="error-page" id="main-content">
    <p class="error-emoji">🌙</p>
    <h1 class="error-title">페이지를 찾을 수 없습니다</h1>
    <p class="error-desc">요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.</p>
    <div class="error-actions">
      <a href="/" class="btn btn-primary">홈으로 가기</a>
      <a href="/search" class="btn btn-secondary">꿈 검색하기</a>
    </div>
  </main>
</BaseLayout>
