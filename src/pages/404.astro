---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n';

export const prerender = false;
---
<BaseLayout title={t('ko', 'seo.notFound.title')}>
  <main class="error-page" id="main-content">
    <p class="error-emoji"><span aria-hidden="true">🌙</span></p>
    <h1 class="error-title">{t('ko', 'seo.notFound.title')}</h1>
    <p class="error-desc">{t('ko', 'seo.notFound.description')}</p>
    <div class="error-actions">
      <a href="/" class="btn btn-primary">{t('ko', 'common.home')}</a>
      <a href="/search" class="btn btn-secondary">{t('ko', 'nav.search')}</a>
    </div>
  </main>
</BaseLayout>
