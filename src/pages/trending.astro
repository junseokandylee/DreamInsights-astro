---
import BaseLayout from '../layouts/BaseLayout.astro';
import { query } from '../lib/db';

export const prerender = false;

const [popularRecent, popularAllTime] = await Promise.all([
  query<any>(`SELECT d.id, d.original_slug as slug, d.views, t.title, t.summary, c.name as category_name FROM dream_interpretations d JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true LEFT JOIN categories c ON d.category_id = c.id WHERE d.is_active = true AND d.created_at > NOW() - INTERVAL '30 days' ORDER BY d.views DESC NULLS LAST LIMIT 12`),
  query<any>(`SELECT d.id, d.original_slug as slug, d.views, t.title, t.summary, c.name as category_name FROM dream_interpretations d JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true LEFT JOIN categories c ON d.category_id = c.id WHERE d.is_active = true ORDER BY d.views DESC NULLS LAST LIMIT 12`)
]);
---

<BaseLayout title="인기 꿈 해몽 - 드림디비" description="가장 많이 조회된 꿈 해몽과 최근 30일 인기 해몽을 확인하세요.">
  <div class="container-wide page-section">
    <h1 class="heading-1 mb-8">인기 꿈 해몽</h1>

    <div class="tab-bar">
      <button class="trending-tab trending-tab-active" data-target="recent">최근 30일 🔥</button>
      <button class="trending-tab" data-target="alltime">역대 인기 🏆</button>
    </div>

    <div id="tab-recent" class="dream-grid">
      {popularRecent.map((dream: any, i: number) => (
        <a href={`/dream/${dream.slug}`} class="card dream-card">
          <div class="dream-card-meta">
            <span class="text-bold text-xl text-accent" style="opacity:0.5; font-family:var(--font-family-display);">{i + 1}</span>
            {dream.category_name && <span class="category-pill">{dream.category_name}</span>}
            <span class="dream-card-views">👁 {(dream.views || 0).toLocaleString()}</span>
          </div>
          <h3 class="dream-card-title">{dream.title}</h3>
          <p class="dream-card-summary">{dream.summary || dream.content?.slice(0, 120)}</p>
        </a>
      ))}
    </div>

    <div id="tab-alltime" class="dream-grid" style="display:none;">
      {popularAllTime.map((dream: any, i: number) => (
        <a href={`/dream/${dream.slug}`} class="card dream-card">
          <div class="dream-card-meta">
            <span class="text-bold text-xl text-accent" style="opacity:0.5; font-family:var(--font-family-display);">{i + 1}</span>
            {dream.category_name && <span class="category-pill">{dream.category_name}</span>}
            <span class="dream-card-views">👁 {(dream.views || 0).toLocaleString()}</span>
          </div>
          <h3 class="dream-card-title">{dream.title}</h3>
          <p class="dream-card-summary">{dream.summary || dream.content?.slice(0, 120)}</p>
        </a>
      ))}
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.trending-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.trending-tab').forEach(t => {
          t.style.borderBottom = '2px solid transparent';
          t.style.color = 'var(--color-text-secondary)';
          t.classList.remove('trending-tab-active');
        });
        tab.style.borderBottom = '2px solid var(--color-accent)';
        tab.style.color = 'var(--color-accent)';
        tab.classList.add('trending-tab-active');
        const target = tab.dataset.target;
        document.querySelectorAll('#tab-recent, #tab-alltime').forEach(panel => {
          panel.style.display = panel.id === 'tab-' + target ? 'grid' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
