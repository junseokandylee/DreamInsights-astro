---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { query } from '../../lib/db';

export const prerender = false;

const { slug } = Astro.params;
const decodedSlug = decodeURIComponent(slug!);

// Fetch dream
const dreams = await query<any>(`
  SELECT
    d.id, d.original_slug as slug, d.category_id,
    d.views, d.shares, d.created_at, d.updated_at,
    t.title, t.content, t.summary,
    t.meta_title, t.meta_description,
    c.name as category_name, c.slug as category_slug
  FROM dream_interpretations d
  JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true
  LEFT JOIN categories c ON d.category_id = c.id
  WHERE d.original_slug = $1 AND d.is_active = true
`, [decodedSlug]);

const dream = dreams[0];
if (!dream) return Astro.redirect('/404');

// Related dreams
const related = await query<any>(`
  SELECT d.original_slug as slug, d.views,
         t.title, t.content, t.summary,
         c.name as category_name
  FROM dream_interpretations d
  JOIN interpretation_content t ON d.id = t.interpretation_id AND t.language_code = 'ko' AND t.is_active = true
  LEFT JOIN categories c ON d.category_id = c.id
  WHERE d.category_id = $1 AND d.original_slug != $2 AND d.is_active = true
  ORDER BY d.views DESC NULLS LAST
  LIMIT 9
`, [dream.category_id, decodedSlug]);

// Content parsing
const contentParts = dream.content.split('##').filter(Boolean);
const mainContent = contentParts[0]?.trim() || dream.content;
const sections = contentParts.slice(1).map((s: string) => {
  const lines = s.split('\n');
  return { title: lines[0]?.trim(), body: lines.slice(1).join('\n').trim() };
});

// View count increment
query(`UPDATE dream_interpretations SET views = COALESCE(views, 0) + 1 WHERE id = $1`, [dream.id]).catch(() => {});

const baseUrl = 'https://dream-db.net';
const ogDescription = dream.meta_description || dream.summary || mainContent.slice(0, 160);
---

<BaseLayout
  title={dream.meta_title || dream.title}
  description={ogDescription}
  type="article"
  canonicalUrl={`${baseUrl}/dream/${dream.slug}`}
>
  <!-- Reading Progress -->
  <div class="reading-progress" id="reading-progress"></div>

  <article style="max-width:var(--max-width-content); margin:0 auto; padding:0 var(--space-4);">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" style="padding:var(--space-4) 0;">
      <a href="/">홈</a>
      <span class="separator">›</span>
      {dream.category_name ? (
        <>
          <a href={`/category/${dream.category_slug}`}>{dream.category_name}</a>
          <span class="separator">›</span>
        </>
      ) : null}
      <span style="color:var(--color-text-secondary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:200px;">{dream.title}</span>
    </nav>

    <!-- Article Header -->
    <header style="margin-bottom:var(--space-8);">
      <div style="display:flex; align-items:center; gap:var(--space-2); margin-bottom:var(--space-4);">
        {dream.category_name && <a href={`/category/${dream.category_slug}`} class="category-pill" style="text-decoration:none;">{dream.category_name}</a>}
      </div>
      <h1 class="heading-1" style="max-width:640px; margin-bottom:var(--space-4);">
        {dream.title}
      </h1>
      <div style="display:flex; align-items:center; gap:var(--space-4); font-size:var(--font-size-sm); color:var(--color-text-tertiary);">
        <span style="display:flex; align-items:center; gap:4px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          {(dream.views || 0).toLocaleString()}회 조회
        </span>
        {dream.updated_at && (
          <time datetime={dream.updated_at} style="display:flex; align-items:center; gap:4px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {new Date(dream.updated_at).toLocaleDateString('ko-KR', { year:'numeric', month:'long', day:'numeric' })}
          </time>
        )}
      </div>
    </header>

    <!-- Main Content — Optimized for long-form reading -->
    <div class="body-reading" style="font-size:17px; line-height:1.8; margin-bottom:var(--space-8);">
      <p style="margin-bottom:var(--space-6); font-size:18px; color:var(--color-text-primary); line-height:1.8;">
        {mainContent}
      </p>
      {sections.map((section: any) => (
        <div style="margin-top:var(--space-8); padding-top:var(--space-6); border-top:1px solid var(--color-border-default);">
          <h2 style="font-family:var(--font-family-display); font-size:var(--font-size-xl); font-weight:var(--font-weight-bold); color:var(--color-text-primary); margin-bottom:var(--space-4); line-height:var(--line-height-snug);">
            {section.title}
          </h2>
          <p style="line-height:1.8; color:var(--color-text-secondary); white-space:pre-line;">{section.body}</p>
        </div>
      ))}
    </div>

    <!-- Inline Ad (mid-article) -->
    <div class="ad-slot ad-slot-inline" style="max-width:var(--max-width-content);">광고 영역</div>

    <!-- Share & Actions -->
    <div style="display:flex; align-items:center; gap:var(--space-3); padding:var(--space-6) 0; border-top:1px solid var(--color-border-default); border-bottom:1px solid var(--color-border-default); flex-wrap:wrap;">
      <span style="font-size:var(--font-size-sm); color:var(--color-text-tertiary);">이 해몽이 도움이 되셨나요?</span>
      <button id="helpful-btn" data-dream-id={dream.id} style="padding:var(--space-2) var(--space-4); background:var(--color-accent); color:white; border:none; border-radius:var(--radius-full); font-size:var(--font-size-sm); font-weight:var(--font-weight-medium); cursor:pointer; transition:opacity var(--transition-fast);">👍 도움됐어요 <span id="helpful-count"></span></button>
      <button id="share-btn" style="padding:var(--space-2) var(--space-4); background:var(--color-background-muted); color:var(--color-text-secondary); border:1px solid var(--color-border-default); border-radius:var(--radius-full); font-size:var(--font-size-sm); font-weight:var(--font-weight-medium); cursor:pointer; transition:all var(--transition-fast);">📋 공유하기</button>
      <span id="share-toast" style="display:none; padding:var(--space-2) var(--space-3); background:var(--color-success); color:white; border-radius:var(--radius-full); font-size:var(--font-size-xs); font-weight:var(--font-weight-medium);">복사 완료!</span>
    </div>

    <!-- Related Dreams -->
    {related.length > 0 && (
      <section style="padding:var(--space-10) 0;">
        <h2 class="heading-2" style="margin-bottom:var(--space-6);">같은 카테고리의 해몽</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:var(--space-4);">
          {related.map((r: any) => (
            <a href={`/dream/${r.slug}`} class="card" style="padding:var(--space-4); text-decoration:none;">
              <div style="display:flex; align-items:center; gap:var(--space-2); margin-bottom:var(--space-2);">
                {r.category_name && <span class="category-pill" style="font-size:11px;">{r.category_name}</span>}
              </div>
              <h3 style="font-size:var(--font-size-sm); font-weight:var(--font-weight-semibold); color:var(--color-text-primary); line-height:var(--line-height-snug); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin-bottom:var(--space-1);">
                {r.title}
              </h3>
              <p style="font-size:var(--font-size-xs); color:var(--color-text-tertiary); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                {r.summary || r.content?.slice(0, 80)}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Bottom Ad -->
    <div class="ad-slot ad-slot-inline" style="max-width:var(--max-wide);">광고 영역</div>
  </article>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": dream.title,
    "description": ogDescription,
    "author": { "@type": "Organization", "name": "드림디비 AI" },
    "publisher": {
      "@type": "Organization",
      "name": "드림디비",
      "logo": { "@type": "ImageObject", "url": `${baseUrl}/logo.png` }
    },
    "datePublished": dream.created_at,
    "dateModified": dream.updated_at,
    "mainEntityOfPage": { "@type": "WebPage", "@id": `${baseUrl}/dream/${dream.slug}` }
  })} />

  <!-- Reading Progress Script -->
  <script is:inline>
    const bar = document.getElementById('reading-progress');
    window.addEventListener('scroll', () => {
      const h = document.documentElement;
      const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    });

    // Helpfulness button
    const helpfulBtn = document.getElementById('helpful-btn');
    const helpfulCount = document.getElementById('helpful-count');
    const STORAGE_KEY = 'dreamdb_helpful';
    if (helpfulBtn) {
      const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      const dreamId = helpfulBtn.dataset.dreamId;
      if (stored[dreamId]) {
        helpfulBtn.style.opacity = '0.5';
        helpfulBtn.style.cursor = 'default';
        helpfulBtn.textContent = '👍 도움됨';
      }
      helpfulBtn.addEventListener('click', () => {
        if (stored[dreamId]) return;
        stored[dreamId] = true;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(stored));
        helpfulBtn.style.opacity = '0.5';
        helpfulBtn.style.cursor = 'default';
        helpfulBtn.textContent = '👍 도움됨';
      });
    }

    // Share button — Web Share API with clipboard fallback
    const shareBtn = document.getElementById('share-btn');
    const shareToast = document.getElementById('share-toast');
    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        const url = window.location.href;
        const title = document.querySelector('h1')?.textContent || '';
        if (navigator.share) {
          try { await navigator.share({ title, url }); return; } catch {}
        }
        await navigator.clipboard.writeText(url);
        shareToast.style.display = 'inline';
        setTimeout(() => shareToast.style.display = 'none', 2000);
      });
    }
  </script>
</BaseLayout>
